+# Detect architecture for ISA-specific flags
+ARCH := $(shell uname -m)
+ifeq ($(ARCH), riscv64)
+    ARCH_FLAGS = -march=rv64gc
+else
+    ARCH_FLAGS = -march=native
+endif
+
